cmake_minimum_required(VERSION 3.10)
project(PSO_Project)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED True)

# デバッグ用の最適化フラグ (-g を有効化)
set(CMAKE_BUILD_TYPE Debug)

# CppUTest のパスを手動設定
set(CPPUTEST_DIR "/home/mcqueen/cpputest")
include_directories(${CPPUTEST_DIR}/include)
link_directories(${CPPUTEST_DIR}/lib)

# PSO 実行用プログラム
add_executable(AllTests AllTests.cpp PSO.cpp PSOTest.cpp Optimizer.cpp)

# CppUTest をリンク
target_link_libraries(AllTests CppUTest)
